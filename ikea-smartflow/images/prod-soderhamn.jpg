EA Family offer"},"priceExcludingTaxText":"Price incl. of all taxes"}},"productSummaryProps":{"articleNumberLabel":"Article number","description":"If you like the stylish airy look, you have to try the deep generous seats. Create your own personal combination of SÖDERHAMN sofa, then sit down and relax – by yourself or together with the whole family.","productName":"SÖDERHAMN","showAsNonSellableProduct":false,"visibleItemNo":"094.497.07","locateInStoreLinkText":"Locate product in store","priceDisclaimersProps":{"priceDisclaimers":["Delivery and assembly prices not included."]}},"contentRecFragmentUrls":{"imc":"/in/en/content-rec/fragments/dynamic/skeleton/compact-feed-imc/compact-feed-imc-fragment.html?productId=09449707","vugc":"/in/en/content-rec/fragments/dynamic/skeleton/compact-feed-vugc/compact-feed-vugc-fragment.html?productId=09449707"},"lowerFunnelFragmentUrls":{"comingSoon":"/in/en/lower-funnel-fragments/coming-soon/?itemNo=09449707&inline"},"accessoriesFragmentUrl":"/in/en/pip/fragments/accessories/?itemNo=09449707&inline","breadcrumbsSource":"/in/en/navigation/breadcrumbs/47388.html?page-title=~S%C3%96DERHAMN~%204-seat%20sofa%20with%20chaise%20longue&page-url=https://www.ikea.com/in/en/p/soederhamn-4-seat-sofa-with-chaise-longue-and-open-end-fridtuna-light-beige-s09449707/","categoryShortcutsProps":{"shortcuts":[{"id":"47388","name":"Sofas with chaise longues","url":"https://www.ikea.com/in/en/cat/sofas-with-chaise-longues-47388/","productCount":148,"imageUrl":"https://www.ikea.com/global/assets/range-categorisation/images/product/fabric-sofas-with-chaise-longues-47388.jpeg"},{"id":"10668","name":"Two Seater Sofas","url":"https://www.ikea.com/in/en/cat/two-seat-sofas-10668/","productCount":95,"imageUrl":"https://www.ikea.com/in/en/range-categorisation/images/product/two-seat-sofas-10668.jpeg"},{"id":"10670","name":"Three Seater Sofas","url":"https://www.ikea.com/in/en/cat/three-seat-sofas-10670/","productCount":118,"imageUrl":"https://www.ikea.com/in/en/range-categorisation/images/product/three-seat-sofas-10670.jpeg"},{"id":"22178","name":"SÖDERHAMN serie","url":"https://www.ikea.com/in/en/cat/soederhamn-serie-22178/","productCount":174}],"parentCategory":{"name":"Sofas","url":"https://www.ikea.com/in/en/cat/sofas-fu003/"}},"discoveryFragments":{"buyerProtections":null,"rewardsPromotion":"/in/en/listing/fragments/exp/rewards-promotion/?value=79040&inline"},"highlightedReviews":[],"listingRecFragments":{"similarProductsWithExplore":{"src":"/in/en/listing/fragments/similar-products-with-explore/?q=09449707&filters=f-type:4-seat%20sofa%20with%20chaise%20longue","header":"Similar products","attributionLabel":"rec-pip-similar-products-with-explore"},"similarProducts":{"src":"/in/en/listing/fragments/product-rec/similar-products/?layoutMode=carousel&cardType=standard&baseProduct=09449707","header":"Related products","attributionLabel":"rec-pip-similar-products"},"recommendedForYou":{"src":"/in/en/listing/fragments/product-rec/recommended-for-you/?layoutMode=carousel&cardType=standard&baseProduct=09449707","header":"Recommended for you","attributionLabel":"rec-pip-recommended-for-you"},"moreFrom":{"src":"/in/en/listing/fragments/product-rec/more-from/?layoutMode=carousel&cardType=standard&baseProduct=09449707","header":"More from the SÖDERHAMN serie","attributionLabel":"rec-pip-more-from"},"accessories":{"src":"/in/en/listing/fragments/product-rec/accessories/?layoutMode=carousel&cardType=standard&baseProduct=09449707","header":"Accessories for SÖDERHAMN","attributionLabel":"rec-pip-accessories"}},"miniPlannerProps":{"headUrl":"https://www.ikea.com/in/en/planners/v1/fragments/head/?fragments=banner-mini","url":"https://www.ikea.com/in/en/planners/v1/fragments/banner-mini/09449707/?template=link","isProminent":true},"plannerProps":{"headUrl":"https://www.ikea.com/in/en/planners/v1/fragments/head/?fragments=banner-large","url":"https://www.ikea.com/in/en/planners/v1/fragments/banner-large/09449707/"},"productInformationSectionProps":{"productDetailsProps":{"accordionObject":{"materialsAndCare":{"id":"product-details-material-and-care","title":"Materials and care","contentProps":{"materials":[{"materials":[{"material":"Polyester wadding","part":"Smoulder resistant lining/ Smoulder resistant lining:"},{"material":"Polypropylene plastic","part":"Clip:"},{"material":"Fibreboard, Plywood, Solid wood, Steel, Felt liner","part":"Frame:"},{"material":"100 % polyester - hollow fibre (100% recycled)","part":"Back cushion:"},{"material":"Highly resilient polyurethane foam (cold foam) 35 kg/cu.m., Polyurethane foam 20 kg/cu.m.","part":"Upholstery material:"}],"productType":"Frame, 3-seat section"},{"materials":[{"material":"Plywood, Fibreboard, Steel, Solid wood, Felt liner","part":"Frame:"},{"material":"100 % polyester - hollow fibre (100% recycled)","part":"Back cushion:"},{"material":"Highly resilient polyurethane foam (cold foam) 35 kg/cu.m., Polyurethane foam 20 kg/cu.m.","part":"Upholstery material:"},{"material":"Polypropylene plastic","part":"Clip:"},{"material":"Polyester wadding","part":"Smoulder resistant lining/ Smoulder resistant lining:"}],"productType":"Chaise longue frame"},{"materials":[{"material":"Fibreboard, Solid wood","part":"Frame:"},{"material":"Polyurethane foam 20 kg/cu.m.","part":"Upholstery material:"},{"material":"Polyester wadding","part":"Smoulder resistant lining:"}],"productType":"Frame armrest"},{"materials":[{"material":"78% cotton, 22% polyester (min. 90% recycled)"}],"productType":"Cover for armrest"},{"materials":[{"material":"78% cotton, 22% polyester (min. 90% recycled)","part":"Fabric:"},{"material":"100 % polyester (100% recycled)","part":"Back fabric:"}],"productType":"Cover for chaise longue/ cover for 3-seat section"}],"materialsAndCareLinks":[],"careInstructions":[],"proposition65":[],"detailsMaterialText":"Material","detailsCareText":"Care","ariaOpensInNewTabLabel":"{text} (opens in a new tab)","warningText":"Warning"}},"safetyAndCompliance":{"id":"product-details-safety-and-compliance","title":"Safety and compliance","contentProps":{"safetyAndCompliance":[{"name":"Test results and compliance","text":"This cover's ability to resist abrasion has been tested to handle 25,000 cycles. A cover that withstands 15,000 cycles or more is suitable for furniture that should withstand everyday use in the home."},{"name":"Test results and compliance","text":"The cover has a lightfastness level of 5 (the ability to resist colour fading) on a scale of 1 to 8. According to industry standards, a lightfastness level of 4 or higher is suitable for home use."},{"name":"Test results and compliance","text":"This seating furniture is tested and complies with relevant strength and durability standards. The tests simulate typical usage of the product and are based on use by persons weighing up to 110 kg."}],"safetyAndComplianceLinks":[],"ariaOpensInNewTabLabel":"{text} (opens in a new tab)"}},"assemblyAndDocuments":{"id":"product-details-assembly-and-documents","title":"Assembly and documents","contentProps":{"ariaOpensInNewTabLabel":"{text} (opens in a new tab)","assemblyVideos":[],"attachments":{"assembly":{"header":"Assembly instructions","attachments":[{"id":"202.239.19","url":"https://www.ikea.com/in/en/assembly_instructions/soederhamn-frame-3-seat-section__AA-568227-4-100.pdf","label":"SÖDERHAMN Frame, 3-seat section"},{"id":"602.238.99","url":"https://www.ikea.com/in/en/assembly_instructions/soederhamn-chaise-longue-frame__AA-568231-5-100.pdf","label":"SÖDERHAMN Chaise longue frame"},{"id":"305.190.05","url":"https://www.ikea.com/in/en/assembly_instructions/soederhamn-cover-for-chaise-longue-fridtuna-light-beige__AA-2641295-1-100.pdf","label":"SÖDERHAMN Cover for chaise longue"},{"id":"905.190.12","url":"https://www.ikea.com/in/en/assembly_instructions/soederhamn-cover-for-3-seat-section-fridtuna-light-beige__AA-2640985-1-100.pdf","label":"SÖDERHAMN Cover for 3-seat section"}]},"software":{"header":"Software","attachments":[]},"declaration":{"header":"Declaration of Conformity","attachments":[]},"other":{"header":"Other documents","attachments":[]},"customerDisassembly":{"header":"Disassembly instructions","attachments":[]},"professionalDisassembly":{"header":"Disassembly & Recycling (For industry professionals)","attachments":[]},"manual":{"header":"Advice and care instructions","attachments":[{"id":"202.239.19","url":"https://www.ikea.com/in/en/manuals/soederhamn-frame-3-seat-section__AA-2666808-2-100.pdf","label":"SÖDERHAMN Frame, 3-seat section"},{"id":"602.238.99","url":"https://www.ikea.com/in/en/manuals/soederhamn-chaise-longue-frame__AA-2666808-2-100.pdf","label":"SÖDERHAMN Chaise longue frame"},{"id":"702.238.94","url":"https://www.ikea.com/in/en/manuals/soederhamn-frame-armrest__AA-2666808-2-100.pdf","label":"SÖDERHAMN Frame armrest"}]}}}}},"articleNumberLabel":"Article number","productDescriptionProps":{"paragraphs":["SÖDERHAMN seating series allows you to sit deeply, low and softly with the loose back cushions for extra support.","Light, airy design with high legs and slim lines, yet still a great comfort thanks to the elastic weave in the bottom and high resilience foam in the seat cushions.","The sofa's sections can be used freestanding or combined in different ways to get a size and shape that suits you and your home.","If you need a larger sofa, you can add a section or two to your existing combination.","You can create your own perfect combination with the planning tool. Assemble, take apart and put together again until it’s just right.","The removable back cushions give your body support where needed. For example, place several behind your back for a more upright position or use them to make it comfortable when lying down and reading.","The depth of the sofa makes it perfect for relaxing or even taking a nice nap.","You can place the chaise longue section to the left or right of the sofa, and switch whenever you like.","You can choose to use the sofa with or without armrests, depending on the expression you want to create.","The high legs make it easy to clean the floor under the sofa.","This cover is made of Fridtuna, a sturdy cotton and polyester fabric with a deep texture woven in different tones.","The cover is easy to keep clean since it can be machine washed and is easy to take off and put on again."],"designerLabel":"Designer","designerName":""},"productId":"09449707","title":"Product details"},"includedProductsProps":{"eventLabel":"pip_whats_included","includedProductCardsProps":[{"additionalText":"","subtitle":"SÖDERHAMN","title":"1 x Frame, 3-seat section","url":"https://www.ikea.com/in/en/p/soederhamn-frame-3-seat-section-20223919/","visibleItemNo":"202.239.19"},{"additionalText":"","subtitle":"SÖDERHAMN","title":"1 x Chaise longue frame","url":"https://www.ikea.com/in/en/p/soederhamn-chaise-longue-frame-60223899/","visibleItemNo":"602.238.99"},{"additionalText":"","subtitle":"SÖDERHAMN","title":"1 x Frame armrest","url":"https://www.ikea.com/in/en/p/soederhamn-frame-armrest-70223894/","visibleItemNo":"702.238.94"},{"additionalText":"","image":{"alt":"Tight-weave beige fabric with fine texture, showcasing durable quality.","height":2000,"id":"1208571_PE908636","imageFileName":"1208571_PE908636_S5.JPG","items":[{"itemNo":"40519000"}],"orientation":"SQUARE","type":"QUALITY_PRODUCT_IMAGE","url":"https://www.ikea.com/in/en/images/products/soederhamn-cover-for-armrest-fridtuna-light-beige__1208571_pe908636_s5.jpg","width":2000},"subtitle":"SÖDERHAMN","title":"1 x Cover for armrest","url":"https://www.ikea.com/in/en/p/soederhamn-cover-for-armrest-fridtuna-light-beige-80519003/","visibleItemNo":"805.190.03"},{"additionalText":"","image":{"alt":"Close-up of SÖDERHAMNs textured, durable fabric with intricate weave patterns.","height":2000,"id":"1208571_PE908636","imageFileName":"1208571_PE908636_S5.JPG","items":[{"itemNo":"40519000"}],"orientation":"SQUARE","type":"QUALITY_PRODUCT_IMAGE","url":"https://www.ikea.com/in/en/images/pro