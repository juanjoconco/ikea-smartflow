ome","IKEA_LOGO_ACCESSIBLE_LABEL":"IKEA Home","LOCALISATION_CANCEL_MODAL":"Cancel","LOCALISATION_CHANGE_COUNTRY_DISCLAIMER":"Your shopping bag will empty if you change to a different country/region.","LOCALISATION_CHANGE_COUNTRY_LINK":"Change country/region","LOCALISATION_CURRENT_STORE_HEADING":"You're in the India online store","LOCALISATION_SELECT_LANGUAGE":"Select your preferred language","LOCATION_OPEN_24H":"Open 24 hours","LOCATION_OPEN_TODAY":"Open today {{from - to}}","LOCATION_OPEN_TODAY_24H":"Open 24 hours today","LOCATION_OPEN_TOMORROW":"Open tomorrow {{from - to}}","LOCATION_OPEN_TOMORROW_24H":"Open 24 hours tomorrow","LOCATION_OPEN_UNTIL":"Open until {{closing time}}","LOCATION_POPUP_CANCEL":"No, thanks","LOCATION_POPUP_CONFIRM":"Yes, go there","LOCATION_POPUP_DESCRIPTION_1":"Did you know that you’re visiting the {{country}} site right now?","LOCATION_POPUP_DESCRIPTION_2":"Would you like to visit the IKEA {{country}} site instead?","LOCATION_POPUP_HEADING":"Hey, Earthling!","LOCATION_POPUP_REMEMBER_CHOICE":"Remember my choice","LOCATION_SEE_OPENING_HOURS":"See opening hours","LOCATION_SELECT_STORE":"Select store","LOCATION_TIMESPAN_FORMAT":"{{from}} - {{to}}","PAYMENT_OPTIONS_HEADING":"Payment options","POSTALCODE_PICKER_CONFIRM_MESSAGE":"You've selected {{postal code}} as your postcode","POSTALCODE_PICKER_CONSENT":"We use cookies to provide this service. Read more about how we use cookies in {{cookie policy link}}. Please note that your location won’t be shared.","POSTALCODE_PICKER_CONSENT_OUR_POLICY":"our policy","POSTALCODE_PICKER_DELIVERY_INFO":"For delivery info","POSTALCODE_PICKER_DELIVERY_TO":"Delivery to","POSTALCODE_PICKER_ENTER_POSTALCODE":"Enter postal code","POSTALCODE_PICKER_ENTER_YOUR_POSTALCODE":"Use your location","POSTALCODE_PICKER_ENTER_YOUR_POSTALCODE_DESC":"Get updated information about product delivery and stock availability for your area.","POSTALCODE_PICKER_FORGET":"Forget postal code","POSTALCODE_PICKER_NUDGE_AUTOLOCATION_TEXT":"H